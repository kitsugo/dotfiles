#!/bin/sh
# Get current mediaplayer (playerctl) info
icon=$([ "$(playerctl --player=mpv status)" = "Playing" ] && echo "箚릨" || echo "箚룮")
title=$(playerctl --player=mpv metadata title)
playerctl --player=mpv metadata --format "$icon ${title%%.*} {{ duration(position) }}/{{ duration(mpris:length) }}"
